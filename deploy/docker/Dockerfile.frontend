# OmniLLM-Studio frontend container image.
#
# Builds the Vite SPA and serves it from nginx. nginx also reverse-proxies
# /v1/* to the backend, with SSE-safe settings.
#
# Build context: repository root.
#   docker build -f deploy/docker/Dockerfile.frontend \
#     -t omnillm-studio-frontend:dev .

# --- build ---
FROM node:26-alpine AS build

WORKDIR /src
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ ./
RUN npm run build

# --- runtime ---
FROM nginxinc/nginx-unprivileged:1.31-alpine

# Default config: backend on localhost:8080 (combined / sidecar topology).
# Helm chart mounts a ConfigMap-backed override for the split topology.
COPY deploy/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /src/dist /usr/share/nginx/html

EXPOSE 8081
