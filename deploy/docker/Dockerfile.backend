# OmniLLM-Studio backend container image.
#
# The runtime intentionally includes FFmpeg/FFprobe because Video Edit Studio
# advertises timeline rendering and media probing in container deployments.
# Build context: repository root.

# --- build ---
# Build inside the target-platform image. This is slower than pure Go cross
# compilation under QEMU, but it is deterministic for CGO and guarantees that
# SQLite links against the correct target libc and headers.
FROM --platform=$TARGETPLATFORM golang:1.26-bookworm AS build

ARG VERSION=dev
ARG COMMIT=unknown

RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY backend/go.mod backend/go.sum ./
RUN go mod download
COPY backend/ ./

RUN CGO_ENABLED=1 go build -trimpath \
      -ldflags "-s -w -X main.version=${VERSION} -X main.commit=${COMMIT}" \
      -o /out/omnillm-studio \
      ./cmd/server

# --- runtime ---
FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl ffmpeg \
    && groupadd --system --gid 65532 omnillm \
    && useradd --system --uid 65532 --gid 65532 --home-dir /app --shell /usr/sbin/nologin omnillm \
    && mkdir -p /app /data \
    && chown -R omnillm:omnillm /app /data \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build --chown=omnillm:omnillm /out/omnillm-studio /app/omnillm-studio

VOLUME ["/data"]
EXPOSE 8080

ENV OMNILLM_BIND_ADDRESS=0.0.0.0 \
    OMNILLM_PORT=8080 \
    OMNILLM_DB_PATH=/data/omnillm-studio.db \
    OMNILLM_ATTACHMENTS_DIR=/data/attachments \
    OMNILLM_CHROMEM_DIR=/data/chromem \
    OMNILLM_MAX_UPLOAD_BYTES=524288000 \
    OMNILLM_REQUIRE_MASTER_KEY=true

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl --fail --silent --show-error http://127.0.0.1:8080/v1/health >/dev/null || exit 1

USER omnillm:omnillm
ENTRYPOINT ["/app/omnillm-studio"]
