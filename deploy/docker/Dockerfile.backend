# OmniLLM-Studio backend container image.
#
# Multi-stage build. CGO is required by mattn/go-sqlite3, so the runtime
# stage is distroless/cc (glibc) rather than distroless/static.
#
# Build context: repository root.
#   docker build -f deploy/docker/Dockerfile.backend \
#     --build-arg VERSION=$(git describe --tags --always) \
#     --build-arg COMMIT=$(git rev-parse --short HEAD) \
#     -t omnillm-studio-backend:dev .

# --- build ---
FROM --platform=$BUILDPLATFORM golang:1.24-bookworm AS build

ARG TARGETOS
ARG TARGETARCH
ARG VERSION=dev
ARG COMMIT=unknown

# CGO cross-compilation requires the right toolchain when TARGETARCH != BUILDPLATFORM.
# Install both x86_64 and aarch64 cross GCC so this Dockerfile works under
# `docker buildx --platform=linux/amd64,linux/arm64` from either host arch.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        gcc-x86-64-linux-gnu \
        gcc-aarch64-linux-gnu \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ ./

# Pick the right cross-compiler for the target arch.
RUN set -eux; \
    case "${TARGETARCH}" in \
      amd64) CC=x86_64-linux-gnu-gcc ;; \
      arm64) CC=aarch64-linux-gnu-gcc ;; \
      *) echo "unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    CGO_ENABLED=1 GOOS=${TARGETOS} GOARCH=${TARGETARCH} CC=${CC} \
      go build -trimpath \
        -ldflags "-s -w -X main.version=${VERSION} -X main.commit=${COMMIT}" \
        -o /out/omnillm-studio \
        ./cmd/server

# --- runtime ---
FROM gcr.io/distroless/cc-debian12:nonroot

WORKDIR /app
COPY --from=build /out/omnillm-studio /app/omnillm-studio

# /data is the canonical state directory: SQLite DB, attachments, chromem.
# The Helm chart mounts a PVC here. The image declares the volume so plain
# `docker run` users get an anonymous volume by default.
VOLUME ["/data"]

EXPOSE 8080

ENV OMNILLM_BIND_ADDRESS=0.0.0.0 \
    OMNILLM_PORT=8080 \
    OMNILLM_DB_PATH=/data/omnillm-studio.db \
    OMNILLM_ATTACHMENTS_DIR=/data/attachments \
    OMNILLM_CHROMEM_DIR=/data/chromem

USER nonroot:nonroot
ENTRYPOINT ["/app/omnillm-studio"]
